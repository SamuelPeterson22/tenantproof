{
  "name": "tenantproof",
  "version": "0.1.0",
  "description": "Authorization regression checks for Supabase applications built with AI coding tools",
  "type": "module",
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "bin": {
    "tenantproof": "bin/tenantproof.js"
  },
  "scripts": {
    "test": "node --test test/*.test.js",
    "test:syntax": "node --check bin/tenantproof.js && node --check src/*.js",
    "check": "node ./bin/tenantproof.js verify --project ./test/fixtures/insecure",
    "test:integration": "./test/integration/run-local.sh",
    "prepublishOnly": "node --test test/*.test.js && node ./bin/tenantproof.js --help"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "supabase",
    "rls",
    "row-level-security",
    "security",
    "authorization",
    "multi-tenant",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SamuelPeterson22/tenantproof.git"
  },
  "bugs": {
    "url": "https://github.com/SamuelPeterson22/tenantproof/issues"
  },
  "homepage": "https://samuelpeterson22.github.io/tenantproof/",
  "license": "MIT"
}

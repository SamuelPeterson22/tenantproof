{
  "$schema": "https://tenantproof.dev/schema/v1.json",
  "version": 1,
  "migrationsDirectory": "supabase/migrations",
  "resources": {
    "public.invoices": {
      "ownerColumn": "user_id",
      "tenantColumn": "tenant_id",
      "access": {
        "anonymous": "deny",
        "owner": "read_write",
        "sameTenant": "read",
        "otherTenant": "deny"
      }
    }
  }
}

